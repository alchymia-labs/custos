{
  "$defs": {
    "ArchiveVerificationEvidenceV1": {
      "additionalProperties": false,
      "description": "Fail-closed wheel inspection evidence without a local quarantine path.",
      "properties": {
        "archive_format": {
          "const": "wheel",
          "title": "Archive Format",
          "type": "string"
        },
        "entry_point_ast_verified": {
          "const": true,
          "title": "Entry Point Ast Verified",
          "type": "boolean"
        },
        "entry_point_metadata_verified": {
          "const": true,
          "title": "Entry Point Metadata Verified",
          "type": "boolean"
        },
        "member_count": {
          "minimum": 1,
          "title": "Member Count",
          "type": "integer"
        },
        "total_uncompressed_bytes": {
          "minimum": 1,
          "title": "Total Uncompressed Bytes",
          "type": "integer"
        }
      },
      "required": [
        "archive_format",
        "member_count",
        "total_uncompressed_bytes",
        "entry_point_metadata_verified",
        "entry_point_ast_verified"
      ],
      "title": "ArchiveVerificationEvidenceV1",
      "type": "object"
    },
    "ArtifactMemberRole": {
      "enum": [
        "base_contracts_wheel",
        "nautilus_wheel",
        "strategy_wheel",
        "strategy_manifest",
        "runtime_artifact",
        "attestation_bundle",
        "sbom",
        "contract_schema",
        "source_tree"
      ],
      "title": "ArtifactMemberRole",
      "type": "string"
    },
    "ArtifactMemberV1": {
      "additionalProperties": false,
      "properties": {
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
          "title": "Name",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/ArtifactMemberRole"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "role",
        "name",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "ArtifactMemberV1",
      "type": "object"
    },
    "AttestationEvidenceV1": {
      "additionalProperties": false,
      "properties": {
        "base_contracts_version": {
          "minLength": 1,
          "title": "Base Contracts Version",
          "type": "string"
        },
        "build_inputs": {
          "items": {
            "$ref": "#/$defs/DigestBindingV1"
          },
          "minItems": 1,
          "title": "Build Inputs",
          "type": "array"
        },
        "bundle_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Bundle Sha256",
          "type": "string"
        },
        "engine": {
          "const": "nautilus",
          "title": "Engine",
          "type": "string"
        },
        "engine_toolkit_version": {
          "minLength": 1,
          "title": "Engine Toolkit Version",
          "type": "string"
        },
        "engine_version": {
          "const": "1.230.0",
          "title": "Engine Version",
          "type": "string"
        },
        "issuer": {
          "minLength": 1,
          "title": "Issuer",
          "type": "string"
        },
        "normalized_source_tree_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Normalized Source Tree Sha256",
          "type": "string"
        },
        "python_version": {
          "pattern": "^3\\.12\\.[0-9]+$",
          "title": "Python Version",
          "type": "string"
        },
        "source_commit": {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "title": "Source Commit",
          "type": "string"
        },
        "source_repository": {
          "minLength": 1,
          "title": "Source Repository",
          "type": "string"
        },
        "trust_policy_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Trust Policy Digest",
          "type": "string"
        },
        "trust_policy_id": {
          "minLength": 1,
          "title": "Trust Policy Id",
          "type": "string"
        },
        "trust_policy_version": {
          "minimum": 1,
          "title": "Trust Policy Version",
          "type": "integer"
        },
        "workflow_identity": {
          "minLength": 1,
          "title": "Workflow Identity",
          "type": "string"
        }
      },
      "required": [
        "bundle_sha256",
        "source_repository",
        "source_commit",
        "normalized_source_tree_sha256",
        "issuer",
        "workflow_identity",
        "trust_policy_id",
        "trust_policy_version",
        "trust_policy_digest",
        "python_version",
        "engine",
        "engine_version",
        "base_contracts_version",
        "engine_toolkit_version",
        "build_inputs"
      ],
      "title": "AttestationEvidenceV1",
      "type": "object"
    },
    "DigestBindingV1": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
          "title": "Name",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "name",
        "sha256"
      ],
      "title": "DigestBindingV1",
      "type": "object"
    },
    "SigstoreVerificationEvidenceV1": {
      "additionalProperties": false,
      "description": "Public cryptographic evidence emitted before artifact import.",
      "properties": {
        "bundle_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Bundle Sha256",
          "type": "string"
        },
        "issuer": {
          "minLength": 1,
          "title": "Issuer",
          "type": "string"
        },
        "source_repository": {
          "minLength": 1,
          "title": "Source Repository",
          "type": "string"
        },
        "transparency_log_verified": {
          "title": "Transparency Log Verified",
          "type": "boolean"
        },
        "trusted_root_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Trusted Root Sha256",
          "type": "string"
        },
        "verified_subjects": {
          "items": {
            "$ref": "#/$defs/DigestBindingV1"
          },
          "minItems": 1,
          "title": "Verified Subjects",
          "type": "array"
        },
        "verifier_capability_id": {
          "minLength": 1,
          "title": "Verifier Capability Id",
          "type": "string"
        },
        "workflow_identity": {
          "minLength": 1,
          "title": "Workflow Identity",
          "type": "string"
        }
      },
      "required": [
        "verifier_capability_id",
        "bundle_sha256",
        "trusted_root_sha256",
        "issuer",
        "workflow_identity",
        "source_repository",
        "verified_subjects",
        "transparency_log_verified"
      ],
      "title": "SigstoreVerificationEvidenceV1",
      "type": "object"
    },
    "StrategyArtifactRefV1": {
      "$id": "https://custos.the-alephain-guild/contracts/strategy-artifact-ref-v1.schema.json",
      "additionalProperties": false,
      "description": "Exact executable bytes and evidence, without business lifecycle state.",
      "properties": {
        "artifact_coordinate": {
          "minLength": 1,
          "title": "Artifact Coordinate",
          "type": "string"
        },
        "artifact_kind": {
          "const": "wheel",
          "title": "Artifact Kind",
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Sha256",
          "type": "string"
        },
        "artifact_size_bytes": {
          "exclusiveMinimum": 0,
          "title": "Artifact Size Bytes",
          "type": "integer"
        },
        "attestation": {
          "$ref": "#/$defs/AttestationEvidenceV1"
        },
        "contract_schema_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Contract Schema Sha256",
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Manifest Sha256",
          "type": "string"
        },
        "manifest_size_bytes": {
          "exclusiveMinimum": 0,
          "title": "Manifest Size Bytes",
          "type": "integer"
        },
        "required_runtime_artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactMemberV1"
          },
          "title": "Required Runtime Artifacts",
          "type": "array"
        },
        "sbom_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sbom Sha256",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_kind",
        "artifact_coordinate",
        "artifact_sha256",
        "artifact_size_bytes",
        "manifest_sha256",
        "manifest_size_bytes",
        "attestation",
        "sbom_sha256",
        "contract_schema_sha256"
      ],
      "title": "StrategyArtifactRefV1",
      "type": "object"
    },
    "StrategyExecutionCommandBindingV1": {
      "$id": "https://custos.the-alephain-guild/contracts/strategy-execution-command-binding-v1.schema.json",
      "additionalProperties": false,
      "description": "Artifact fields that a signed Crucible command must bind exactly.",
      "properties": {
        "artifact_ref": {
          "$ref": "#/$defs/StrategyArtifactRefV1"
        },
        "deployment_instance_id": {
          "format": "uuid",
          "title": "Deployment Instance Id",
          "type": "string"
        },
        "deployment_spec_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Deployment Spec Digest",
          "type": "string"
        },
        "deployment_spec_id": {
          "format": "uuid",
          "title": "Deployment Spec Id",
          "type": "string"
        },
        "effective_config_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Effective Config Digest",
          "type": "string"
        },
        "generation": {
          "minimum": 1,
          "title": "Generation",
          "type": "integer"
        },
        "release_bom_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Release Bom Digest",
          "type": "string"
        },
        "release_bom_members": {
          "items": {
            "$ref": "#/$defs/ArtifactMemberV1"
          },
          "minItems": 1,
          "title": "Release Bom Members",
          "type": "array"
        },
        "schema_version": {
          "const": 1,
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "strategy_release_id": {
          "format": "uuid",
          "title": "Strategy Release Id",
          "type": "string"
        }
      },
      "required": [
        "deployment_instance_id",
        "deployment_spec_id",
        "deployment_spec_digest",
        "generation",
        "strategy_release_id",
        "release_bom_digest",
        "release_bom_members",
        "artifact_ref",
        "effective_config_digest"
      ],
      "title": "StrategyExecutionCommandBindingV1",
      "type": "object"
    }
  },
  "$id": "https://custos.the-alephain-guild/contracts/strategy-artifact-pre-import-verification-receipt-v1.schema.json",
  "additionalProperties": false,
  "description": "Public proof of exact command-bound verification before Python import.",
  "properties": {
    "archive": {
      "$ref": "#/$defs/ArchiveVerificationEvidenceV1"
    },
    "artifact_ref_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Artifact Ref Digest",
      "type": "string"
    },
    "command_binding": {
      "$ref": "#/$defs/StrategyExecutionCommandBindingV1"
    },
    "command_binding_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Command Binding Digest",
      "type": "string"
    },
    "local_trust_policy_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Local Trust Policy Digest",
      "type": "string"
    },
    "local_trust_policy_id": {
      "minLength": 1,
      "title": "Local Trust Policy Id",
      "type": "string"
    },
    "local_trust_policy_version": {
      "minimum": 1,
      "title": "Local Trust Policy Version",
      "type": "integer"
    },
    "release_bom_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Release Bom Digest",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "sigstore": {
      "$ref": "#/$defs/SigstoreVerificationEvidenceV1"
    },
    "trusted_root_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Trusted Root Digest",
      "type": "string"
    },
    "verification_profile": {
      "const": "custos-artifact-pre-import-verification-v1",
      "title": "Verification Profile",
      "type": "string"
    },
    "verified_at": {
      "format": "date-time",
      "title": "Verified At",
      "type": "string"
    },
    "verified_entry_point": {
      "minLength": 1,
      "title": "Verified Entry Point",
      "type": "string"
    },
    "verified_members": {
      "items": {
        "$ref": "#/$defs/ArtifactMemberV1"
      },
      "minItems": 1,
      "title": "Verified Members",
      "type": "array"
    }
  },
  "required": [
    "verification_profile",
    "verified_at",
    "command_binding",
    "command_binding_digest",
    "artifact_ref_digest",
    "release_bom_digest",
    "verified_members",
    "local_trust_policy_id",
    "local_trust_policy_version",
    "local_trust_policy_digest",
    "trusted_root_digest",
    "sigstore",
    "archive",
    "verified_entry_point"
  ],
  "title": "StrategyArtifactPreImportVerificationReceiptV1",
  "type": "object"
}
