{
  "$defs": {
    "ArtifactMemberRole": {
      "enum": [
        "base_contracts_wheel",
        "nautilus_wheel",
        "strategy_wheel",
        "strategy_manifest",
        "runtime_artifact",
        "attestation_bundle",
        "sbom",
        "contract_schema",
        "source_tree"
      ],
      "title": "ArtifactMemberRole",
      "type": "string"
    },
    "ArtifactMemberV1": {
      "additionalProperties": false,
      "properties": {
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
          "title": "Name",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/ArtifactMemberRole"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "role",
        "name",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "ArtifactMemberV1",
      "type": "object"
    },
    "DigestBindingV1": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
          "title": "Name",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "name",
        "sha256"
      ],
      "title": "DigestBindingV1",
      "type": "object"
    },
    "RunnerLocalArtifactPolicyDecisionV1": {
      "$id": "https://custos.the-alephain-guild/contracts/v1/runner-local-artifact-policy-decision-v1.schema.json",
      "additionalProperties": false,
      "description": "Custos-owned runner-local decision, independent of Crucible policy.",
      "properties": {
        "artifact_acceptance_receipt_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Acceptance Receipt Digest",
          "type": "string"
        },
        "artifact_evidence_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Evidence Digest",
          "type": "string"
        },
        "artifact_ref_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Ref Digest",
          "type": "string"
        },
        "authority": {
          "const": "custos-runner-local",
          "title": "Authority",
          "type": "string"
        },
        "decision": {
          "const": "accepted",
          "title": "Decision",
          "type": "string"
        },
        "evaluated_at": {
          "format": "date-time",
          "title": "Evaluated At",
          "type": "string"
        },
        "policy_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Policy Digest",
          "type": "string"
        },
        "policy_id": {
          "minLength": 1,
          "title": "Policy Id",
          "type": "string"
        },
        "policy_version": {
          "minimum": 1,
          "title": "Policy Version",
          "type": "integer"
        },
        "release_bom_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Release Bom Digest",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        }
      },
      "required": [
        "authority",
        "policy_id",
        "policy_version",
        "policy_digest",
        "evaluated_at",
        "decision",
        "release_bom_digest",
        "artifact_ref_digest",
        "artifact_evidence_digest",
        "artifact_acceptance_receipt_digest"
      ],
      "title": "RunnerLocalArtifactPolicyDecisionV1",
      "type": "object"
    },
    "StrategyArtifactRefV1": {
      "$id": "https://custos.the-alephain-guild/contracts/v1/strategy-artifact-ref-v1.schema.json",
      "additionalProperties": false,
      "description": "Sole first-production pre-sign execution identity.",
      "properties": {
        "artifact_coordinate": {
          "minLength": 1,
          "title": "Artifact Coordinate",
          "type": "string"
        },
        "artifact_kind": {
          "const": "wheel",
          "title": "Artifact Kind",
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Sha256",
          "type": "string"
        },
        "artifact_size_bytes": {
          "exclusiveMinimum": 0,
          "title": "Artifact Size Bytes",
          "type": "integer"
        },
        "base_contracts_version": {
          "minLength": 1,
          "title": "Base Contracts Version",
          "type": "string"
        },
        "build_inputs": {
          "items": {
            "$ref": "#/$defs/DigestBindingV1"
          },
          "minItems": 1,
          "title": "Build Inputs",
          "type": "array"
        },
        "contract_schema_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Contract Schema Sha256",
          "type": "string"
        },
        "engine": {
          "const": "nautilus",
          "title": "Engine",
          "type": "string"
        },
        "engine_toolkit_version": {
          "minLength": 1,
          "title": "Engine Toolkit Version",
          "type": "string"
        },
        "engine_version": {
          "const": "1.230.0",
          "title": "Engine Version",
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Manifest Sha256",
          "type": "string"
        },
        "manifest_size_bytes": {
          "exclusiveMinimum": 0,
          "title": "Manifest Size Bytes",
          "type": "integer"
        },
        "normalized_source_tree_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Normalized Source Tree Sha256",
          "type": "string"
        },
        "python_version": {
          "pattern": "^3\\.12\\.[0-9]+$",
          "title": "Python Version",
          "type": "string"
        },
        "required_runtime_artifacts": {
          "items": {
            "$ref": "#/$defs/ArtifactMemberV1"
          },
          "minItems": 1,
          "title": "Required Runtime Artifacts",
          "type": "array"
        },
        "sbom_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sbom Sha256",
          "type": "string"
        },
        "schema_version": {
          "const": 1,
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "source_commit": {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "title": "Source Commit",
          "type": "string"
        },
        "source_repository": {
          "minLength": 1,
          "title": "Source Repository",
          "type": "string"
        }
      },
      "required": [
        "artifact_kind",
        "artifact_coordinate",
        "artifact_sha256",
        "artifact_size_bytes",
        "manifest_sha256",
        "manifest_size_bytes",
        "required_runtime_artifacts",
        "sbom_sha256",
        "contract_schema_sha256",
        "source_repository",
        "source_commit",
        "normalized_source_tree_sha256",
        "python_version",
        "engine",
        "engine_version",
        "base_contracts_version",
        "engine_toolkit_version",
        "build_inputs"
      ],
      "title": "StrategyArtifactRefV1",
      "type": "object"
    }
  },
  "$id": "https://custos.the-alephain-guild/contracts/v1/strategy-artifact-pre-import-verification-receipt-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Contract-consumer proof over producer-owned evidence objects.",
  "properties": {
    "artifact_ref": {
      "$ref": "#/$defs/StrategyArtifactRefV1"
    },
    "artifact_ref_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Artifact Ref Digest",
      "type": "string"
    },
    "crucible_artifact_acceptance": {
      "additionalProperties": true,
      "title": "Crucible Artifact Acceptance",
      "type": "object"
    },
    "crucible_artifact_acceptance_receipt_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Crucible Artifact Acceptance Receipt Digest",
      "type": "string"
    },
    "crucible_artifact_evidence": {
      "additionalProperties": true,
      "title": "Crucible Artifact Evidence",
      "type": "object"
    },
    "crucible_artifact_evidence_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Crucible Artifact Evidence Digest",
      "type": "string"
    },
    "detached_attestation_ref": {
      "additionalProperties": true,
      "title": "Detached Attestation Ref",
      "type": "object"
    },
    "detached_attestation_ref_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Detached Attestation Ref Digest",
      "type": "string"
    },
    "release_bom": {
      "additionalProperties": true,
      "title": "Release Bom",
      "type": "object"
    },
    "release_bom_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Release Bom Digest",
      "type": "string"
    },
    "release_statement": {
      "additionalProperties": true,
      "title": "Release Statement",
      "type": "object"
    },
    "release_statement_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Release Statement Digest",
      "type": "string"
    },
    "runner_local_policy_decision": {
      "$ref": "#/$defs/RunnerLocalArtifactPolicyDecisionV1"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "verification_profile": {
      "const": "custos-artifact-pre-import-verification-v1",
      "title": "Verification Profile",
      "type": "string"
    },
    "verified_at": {
      "format": "date-time",
      "title": "Verified At",
      "type": "string"
    }
  },
  "required": [
    "verification_profile",
    "verified_at",
    "release_bom",
    "release_bom_digest",
    "release_statement",
    "release_statement_digest",
    "artifact_ref",
    "artifact_ref_digest",
    "detached_attestation_ref",
    "detached_attestation_ref_digest",
    "crucible_artifact_evidence",
    "crucible_artifact_evidence_digest",
    "crucible_artifact_acceptance",
    "crucible_artifact_acceptance_receipt_digest",
    "runner_local_policy_decision"
  ],
  "title": "StrategyArtifactPreImportVerificationReceiptV1",
  "type": "object"
}
