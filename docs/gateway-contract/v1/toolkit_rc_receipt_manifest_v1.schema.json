{
  "$defs": {
    "ImmutableToolkitArtifactBindingV1": {
      "additionalProperties": false,
      "properties": {
        "coordinate": {
          "minLength": 1,
          "title": "Coordinate",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "exclusiveMinimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "coordinate",
        "sha256",
        "size_bytes"
      ],
      "title": "ImmutableToolkitArtifactBindingV1",
      "type": "object"
    },
    "LockedToolkitDependencyV1": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "title": "Name",
          "type": "string"
        },
        "requirement": {
          "minLength": 1,
          "title": "Requirement",
          "type": "string"
        },
        "version": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._+!-]*$",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "requirement"
      ],
      "title": "LockedToolkitDependencyV1",
      "type": "object"
    },
    "ToolkitRcMemberRole": {
      "enum": [
        "base_contracts_wheel",
        "nautilus_wheel"
      ],
      "title": "ToolkitRcMemberRole",
      "type": "string"
    },
    "ToolkitRcMemberV1": {
      "additionalProperties": false,
      "properties": {
        "contract_asset_index": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "contract_schema": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "dependencies": {
          "items": {
            "$ref": "#/$defs/LockedToolkitDependencyV1"
          },
          "minItems": 1,
          "title": "Dependencies",
          "type": "array"
        },
        "distribution_name": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "title": "Distribution Name",
          "type": "string"
        },
        "nautilus_version": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Nautilus Version"
        },
        "python_requires": {
          "minLength": 1,
          "title": "Python Requires",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/ToolkitRcMemberRole"
        },
        "sbom": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "sigstore_attestation": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "source_commit": {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "title": "Source Commit",
          "type": "string"
        },
        "source_repository": {
          "minLength": 1,
          "title": "Source Repository",
          "type": "string"
        },
        "t4b_typing_closure_receipt": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "t4b_zero_rewrite_receipt": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "t5_pre_import_verifier_receipt": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        },
        "top_level_modules": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Top Level Modules",
          "type": "array"
        },
        "version": {
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+rc[1-9][0-9]*$",
          "title": "Version",
          "type": "string"
        },
        "wheel": {
          "$ref": "#/$defs/ImmutableToolkitArtifactBindingV1"
        }
      },
      "required": [
        "role",
        "distribution_name",
        "version",
        "python_requires",
        "nautilus_version",
        "top_level_modules",
        "dependencies",
        "wheel",
        "sbom",
        "contract_schema",
        "contract_asset_index",
        "sigstore_attestation",
        "source_repository",
        "source_commit",
        "t4b_zero_rewrite_receipt",
        "t4b_typing_closure_receipt",
        "t5_pre_import_verifier_receipt"
      ],
      "title": "ToolkitRcMemberV1",
      "type": "object"
    }
  },
  "$id": "https://custos.the-alephain-guild/contracts/toolkit-rc-receipt-manifest-v1.schema.json",
  "additionalProperties": false,
  "description": "Schema-only foundation for a future immutable toolkit RC receipt.",
  "properties": {
    "candidate_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+rc[1-9][0-9]*$",
      "title": "Candidate Version",
      "type": "string"
    },
    "contract_version": {
      "const": "alephain.custos.toolkit-rc-receipt-manifest.v1",
      "default": "alephain.custos.toolkit-rc-receipt-manifest.v1",
      "title": "Contract Version",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "default": true,
      "title": "Immutable",
      "type": "boolean"
    },
    "members": {
      "items": {
        "$ref": "#/$defs/ToolkitRcMemberV1"
      },
      "maxItems": 2,
      "minItems": 2,
      "title": "Members",
      "type": "array"
    },
    "overwrite_allowed": {
      "const": false,
      "default": false,
      "title": "Overwrite Allowed",
      "type": "boolean"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "candidate_version",
    "members"
  ],
  "title": "ToolkitRcReceiptManifestV1",
  "type": "object"
}
