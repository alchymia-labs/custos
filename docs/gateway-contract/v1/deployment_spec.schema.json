{
  "$defs": {
    "LifecycleState": {
      "enum": [
        "running",
        "paused",
        "stopped",
        "archived"
      ],
      "title": "LifecycleState",
      "type": "string"
    },
    "ProvenanceRef": {
      "additionalProperties": false,
      "properties": {
        "credential_id": {
          "pattern": "^[a-zA-Z0-9_-]{1,128}$",
          "title": "Credential Id",
          "type": "string"
        }
      },
      "required": [
        "credential_id"
      ],
      "title": "ProvenanceRef",
      "type": "object"
    },
    "SandboxConfig": {
      "additionalProperties": false,
      "properties": {
        "starting_balances": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Starting Balances",
          "type": "array"
        }
      },
      "required": [
        "starting_balances"
      ],
      "title": "SandboxConfig",
      "type": "object"
    },
    "TradingMode": {
      "enum": [
        "sandbox",
        "testnet",
        "live"
      ],
      "title": "TradingMode",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Validated local execution view of a canonical Crucible DeploymentSpec.",
  "properties": {
    "code_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Code Hash",
      "type": "string"
    },
    "connector": {
      "minLength": 1,
      "title": "Connector",
      "type": "string"
    },
    "deployment_instance_id": {
      "format": "uuid",
      "title": "Deployment Instance Id",
      "type": "string"
    },
    "deployment_spec_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Deployment Spec Digest",
      "type": "string"
    },
    "generation": {
      "minimum": 1,
      "title": "Generation",
      "type": "integer"
    },
    "leverage": {
      "minimum": 1,
      "title": "Leverage",
      "type": "integer"
    },
    "lifecycle_state": {
      "$ref": "#/$defs/LifecycleState"
    },
    "log_level": {
      "default": "INFO",
      "title": "Log Level",
      "type": "string"
    },
    "nautilus_config": {
      "additionalProperties": true,
      "title": "Nautilus Config",
      "type": "object"
    },
    "pairs": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Pairs",
      "type": "array"
    },
    "promotion_evidence_digest": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Promotion Evidence Digest"
    },
    "promotion_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Promotion Id"
    },
    "provenance_ref": {
      "$ref": "#/$defs/ProvenanceRef"
    },
    "risk_config": {
      "additionalProperties": true,
      "title": "Risk Config",
      "type": "object"
    },
    "sandbox": {
      "anyOf": [
        {
          "$ref": "#/$defs/SandboxConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "spec_id": {
      "format": "uuid",
      "title": "Spec Id",
      "type": "string"
    },
    "strategy_config": {
      "additionalProperties": true,
      "title": "Strategy Config",
      "type": "object"
    },
    "strategy_id": {
      "format": "uuid",
      "title": "Strategy Id",
      "type": "string"
    },
    "strategy_path": {
      "minLength": 1,
      "title": "Strategy Path",
      "type": "string"
    },
    "strategy_registry_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Strategy Registry Name"
    },
    "trading_mode": {
      "$ref": "#/$defs/TradingMode"
    }
  },
  "required": [
    "spec_id",
    "deployment_instance_id",
    "deployment_spec_digest",
    "strategy_id",
    "generation",
    "trading_mode",
    "lifecycle_state",
    "strategy_path",
    "provenance_ref",
    "connector",
    "pairs",
    "leverage",
    "code_hash"
  ],
  "title": "DeploymentSpecPayload v1",
  "type": "object"
}
