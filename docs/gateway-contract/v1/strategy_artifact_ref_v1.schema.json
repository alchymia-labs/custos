{
  "$defs": {
    "ArtifactMemberRole": {
      "enum": [
        "base_contracts_wheel",
        "nautilus_wheel",
        "strategy_wheel",
        "strategy_manifest",
        "runtime_artifact",
        "attestation_bundle",
        "sbom",
        "contract_schema",
        "source_tree"
      ],
      "title": "ArtifactMemberRole",
      "type": "string"
    },
    "ArtifactMemberV1": {
      "additionalProperties": false,
      "properties": {
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "name": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
          "title": "Name",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/ArtifactMemberRole"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "role",
        "name",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "ArtifactMemberV1",
      "type": "object"
    },
    "AttestationEvidenceV1": {
      "additionalProperties": false,
      "properties": {
        "base_contracts_version": {
          "minLength": 1,
          "title": "Base Contracts Version",
          "type": "string"
        },
        "build_inputs": {
          "items": {
            "$ref": "#/$defs/DigestBindingV1"
          },
          "minItems": 1,
          "title": "Build Inputs",
          "type": "array"
        },
        "bundle_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Bundle Sha256",
          "type": "string"
        },
        "engine": {
          "const": "nautilus",
          "title": "Engine",
          "type": "string"
        },
        "engine_toolkit_version": {
          "minLength": 1,
          "title": "Engine Toolkit Version",
          "type": "string"
        },
        "engine_version": {
          "const": "1.230.0",
          "title": "Engine Version",
          "type": "string"
        },
        "issuer": {
          "minLength": 1,
          "title": "Issuer",
          "type": "string"
        },
        "normalized_source_tree_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Normalized Source Tree Sha256",
          "type": "string"
        },
        "python_version": {
          "pattern": "^3\\.12\\.[0-9]+$",
          "title": "Python Version",
          "type": "string"
        },
        "source_commit": {
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
          "title": "Source Commit",
          "type": "string"
        },
        "source_repository": {
          "minLength": 1,
          "title": "Source Repository",
          "type": "string"
        },
        "trust_policy_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Trust Policy Digest",
          "type": "string"
        },
        "trust_policy_id": {
          "minLength": 1,
          "title": "Trust Policy Id",
          "type": "string"
        },
        "trust_policy_version": {
          "minimum": 1,
          "title": "Trust Policy Version",
          "type": "integer"
        },
        "workflow_identity": {
          "minLength": 1,
          "title": "Workflow Identity",
          "type": "string"
        }
      },
      "required": [
        "bundle_sha256",
        "source_repository",
        "source_commit",
        "normalized_source_tree_sha256",
        "issuer",
        "workflow_identity",
        "trust_policy_id",
        "trust_policy_version",
        "trust_policy_digest",
        "python_version",
        "engine",
        "engine_version",
        "base_contracts_version",
        "engine_toolkit_version",
        "build_inputs"
      ],
      "title": "AttestationEvidenceV1",
      "type": "object"
    },
    "DigestBindingV1": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
          "title": "Name",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "name",
        "sha256"
      ],
      "title": "DigestBindingV1",
      "type": "object"
    }
  },
  "$id": "https://custos.the-alephain-guild/contracts/strategy-artifact-ref-v1.schema.json",
  "additionalProperties": false,
  "description": "Exact executable bytes and evidence, without business lifecycle state.",
  "properties": {
    "artifact_coordinate": {
      "minLength": 1,
      "title": "Artifact Coordinate",
      "type": "string"
    },
    "artifact_kind": {
      "const": "wheel",
      "title": "Artifact Kind",
      "type": "string"
    },
    "artifact_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Artifact Sha256",
      "type": "string"
    },
    "artifact_size_bytes": {
      "exclusiveMinimum": 0,
      "title": "Artifact Size Bytes",
      "type": "integer"
    },
    "attestation": {
      "$ref": "#/$defs/AttestationEvidenceV1"
    },
    "contract_schema_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Contract Schema Sha256",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "manifest_size_bytes": {
      "exclusiveMinimum": 0,
      "title": "Manifest Size Bytes",
      "type": "integer"
    },
    "required_runtime_artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactMemberV1"
      },
      "title": "Required Runtime Artifacts",
      "type": "array"
    },
    "sbom_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Sbom Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "artifact_kind",
    "artifact_coordinate",
    "artifact_sha256",
    "artifact_size_bytes",
    "manifest_sha256",
    "manifest_size_bytes",
    "attestation",
    "sbom_sha256",
    "contract_schema_sha256"
  ],
  "title": "StrategyArtifactRefV1",
  "type": "object"
}
