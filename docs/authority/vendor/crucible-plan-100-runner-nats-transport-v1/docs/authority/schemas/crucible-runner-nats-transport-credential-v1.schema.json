{
  "$defs": {
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "durable_config": {
      "additionalProperties": false,
      "properties": {
        "ack_policy": {
          "const": "explicit"
        },
        "consumer_mode": {
          "const": "push_existing_only"
        },
        "deliver_policy": {
          "const": "all"
        },
        "delivery_subject": {
          "maxLength": 512,
          "minLength": 1,
          "pattern": "^[^\\s]+$",
          "type": "string"
        },
        "durable_name": {
          "pattern": "^[A-Za-z0-9_-]{1,64}$",
          "type": "string"
        },
        "filter_subjects": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "pattern": "^[^\\s]+$",
            "type": "string"
          },
          "maxItems": 3,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "max_ack_pending": {
          "const": 1
        },
        "replay_policy": {
          "const": "instant"
        },
        "schema_version": {
          "const": 1
        },
        "stream_name": {
          "pattern": "^[A-Za-z0-9_-]{1,64}$",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "stream_name",
        "durable_name",
        "delivery_subject",
        "filter_subjects",
        "deliver_policy",
        "ack_policy",
        "replay_policy",
        "max_ack_pending",
        "consumer_mode"
      ],
      "type": "object"
    },
    "enrollment_response": {
      "additionalProperties": false,
      "properties": {
        "durable_config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "expires_at": {
          "format": "date-time",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "type": "string"
        },
        "issuer_key_id": {
          "pattern": "^[A-Za-z0-9._:-]{1,128}$",
          "type": "string"
        },
        "issuer_public_key": {
          "pattern": "^A[A-Z2-7]{55}$",
          "type": "string"
        },
        "nats_transport_profile": {
          "const": "runner-v1"
        },
        "nats_user_jwt": {
          "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$",
          "type": "string"
        },
        "nats_user_jwt_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "nats_user_public_key": {
          "pattern": "^U[A-Z2-7]{55}$",
          "type": "string"
        },
        "permission_profile_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "transport_credential_id": {
          "format": "uuid",
          "not": {
            "const": "00000000-0000-0000-0000-000000000000"
          },
          "type": "string"
        },
        "transport_credential_version": {
          "minimum": 1,
          "type": "integer"
        },
        "transport_generation": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "transport_credential_id",
        "transport_credential_version",
        "transport_generation",
        "nats_transport_profile",
        "nats_user_public_key",
        "nats_user_jwt",
        "nats_user_jwt_sha256",
        "permission_profile_sha256",
        "durable_config_sha256",
        "issuer_key_id",
        "issuer_public_key",
        "issued_at",
        "expires_at"
      ],
      "type": "object"
    },
    "mode": {
      "enum": [
        "sandbox",
        "testnet",
        "live"
      ]
    },
    "permission_profile": {
      "additionalProperties": false,
      "properties": {
        "authorized_modes": {
          "items": {
            "$ref": "#/$defs/mode"
          },
          "maxItems": 3,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "profile": {
          "const": "runner-v1"
        },
        "publish_allow": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "pattern": "^[^\\s]+$",
            "type": "string"
          },
          "minItems": 3,
          "type": "array",
          "uniqueItems": true
        },
        "publish_deny": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "pattern": "^[^\\s]+$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "runner_id": {
          "format": "uuid",
          "type": "string"
        },
        "schema_version": {
          "const": 1
        },
        "subscribe_allow": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "pattern": "^[^\\s]+$",
            "type": "string"
          },
          "minItems": 2,
          "type": "array",
          "uniqueItems": true
        },
        "subscribe_deny": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "pattern": "^[^\\s]+$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "tenant_id": {
          "pattern": "^[A-Za-z0-9_-]{1,64}$",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "profile",
        "tenant_id",
        "runner_id",
        "authorized_modes",
        "publish_allow",
        "subscribe_allow",
        "publish_deny",
        "subscribe_deny"
      ],
      "type": "object"
    },
    "subject": {
      "maxLength": 512,
      "minLength": 1,
      "pattern": "^[^\\s]+$",
      "type": "string"
    },
    "token": {
      "pattern": "^[A-Za-z0-9_-]{1,64}$",
      "type": "string"
    },
    "truth": {
      "additionalProperties": false,
      "properties": {
        "arx_proxy_ready": {
          "const": false
        },
        "contract_frozen": {
          "const": true
        },
        "control_0043_checked_in": {
          "const": false
        },
        "control_0043_executed": {
          "const": false
        },
        "control_0043_reserved": {
          "const": true
        },
        "custos_transport_consumer_ready": {
          "const": false
        },
        "durable_provisioned": {
          "const": false
        },
        "live_ready": {
          "const": false
        },
        "mode_migration_allocated": {
          "const": false
        },
        "production_ready": {
          "const": false
        },
        "real_nats_verified": {
          "const": false
        },
        "runtime_ready": {
          "const": false
        },
        "signer_composed": {
          "const": false
        }
      },
      "required": [
        "arx_proxy_ready",
        "contract_frozen",
        "control_0043_checked_in",
        "control_0043_executed",
        "control_0043_reserved",
        "custos_transport_consumer_ready",
        "durable_provisioned",
        "live_ready",
        "mode_migration_allocated",
        "production_ready",
        "real_nats_verified",
        "runtime_ready",
        "signer_composed"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.alephain.org/crucible/runner-nats-transport-credential-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Closed control-plane authority for one Custos-generated NKey, Crucible-issued user JWT, exact broker ACL and existing V4 durable.",
  "properties": {
    "authority": {
      "const": "CR100-RUNNER-NATS-TRANSPORT-AUTHORITY-V1"
    },
    "durable_config": {
      "$ref": "#/$defs/durable_config"
    },
    "enrollment_response": {
      "$ref": "#/$defs/enrollment_response"
    },
    "permission_profile": {
      "$ref": "#/$defs/permission_profile"
    },
    "schema_version": {
      "const": 1
    },
    "truth": {
      "$ref": "#/$defs/truth"
    }
  },
  "required": [
    "schema_version",
    "authority",
    "enrollment_response",
    "permission_profile",
    "durable_config",
    "truth"
  ],
  "title": "Crucible Runner NATS Transport Authority V1",
  "type": "object"
}
