{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.alephain.org/crucible/runner-deployment-command-v1.schema.json",
  "title": "Crucible RunnerDeploymentCommandV1",
  "description": "Closed Crucible-owned desired-state command. Referenced artifact, BOM, attestation, and acceptance schemas remain owned by their declared producers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "tenant_id", "trading_mode", "runner_id",
    "deployment_instance_id", "deployment_spec_id", "deployment_spec_digest", "generation",
    "lifecycle_state", "strategy_release_id", "effective_config", "effective_config_digest",
    "artifact_ref", "artifact_ref_canonical_json", "artifact_ref_digest",
    "release_bom", "release_bom_canonical_json", "release_bom_digest",
    "artifact_attestation_ref", "artifact_evidence", "artifact_acceptance_receipt", "artifact_evidence_digest"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "tenant_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,64}$" },
    "trading_mode": { "type": "string", "enum": ["sandbox", "testnet", "live"] },
    "runner_id": { "type": "string", "format": "uuid" },
    "deployment_instance_id": { "type": "string", "format": "uuid" },
    "deployment_spec_id": { "type": "string", "format": "uuid" },
    "deployment_spec_digest": { "$ref": "#/$defs/sha256" },
    "generation": { "type": "integer", "minimum": 1 },
    "lifecycle_state": { "type": "string", "enum": ["running", "paused", "stopped", "archived"] },
    "strategy_release_id": { "type": "string", "format": "uuid" },
    "effective_config": { "type": "object" },
    "effective_config_digest": { "$ref": "#/$defs/sha256" },
    "artifact_ref": {
      "allOf": [{ "$ref": "../custos-strategy-artifact-ref-v2.schema.json" }],
      "required": ["schema_version"]
    },
    "artifact_ref_canonical_json": { "type": "string", "minLength": 2 },
    "artifact_ref_digest": { "$ref": "#/$defs/sha256" },
    "release_bom": { "$ref": "../ps-strategy-release-bom-v1.schema.json" },
    "release_bom_canonical_json": { "type": "string", "minLength": 2 },
    "release_bom_digest": { "$ref": "#/$defs/sha256" },
    "artifact_attestation_ref": { "$ref": "../ps-artifact-attestation-ref-v1.schema.json" },
    "artifact_evidence": {
      "allOf": [
        { "$ref": "crucible-artifact-evidence-v1.schema.json" },
        { "properties": { "schema_version": { "const": 1 } } }
      ]
    },
    "artifact_acceptance_receipt": {
      "allOf": [
        { "$ref": "crucible-artifact-acceptance-receipt-v1.schema.json" },
        {
          "properties": {
            "schema_version": { "const": 1 },
            "strategy_release_id": { "not": { "const": "00000000-0000-0000-0000-000000000000" } },
            "outbox_event_id": { "not": { "const": "00000000-0000-0000-0000-000000000000" } },
            "actor_id": { "not": { "const": "00000000-0000-0000-0000-000000000000" } },
            "actor_assertion_jti": { "not": { "const": "00000000-0000-0000-0000-000000000000" } },
            "correlation_id": { "not": { "const": "00000000-0000-0000-0000-000000000000" } }
          }
        }
      ]
    },
    "artifact_evidence_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "event_plane": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "trading_mode"],
      "properties": {
        "kind": { "const": "mode" },
        "trading_mode": { "enum": ["sandbox", "testnet", "live"] }
      }
    },
    "event_document_v2": {
      "type": "object", "additionalProperties": false,
      "required": [
        "schema_version", "event_id", "tenant_id", "event_plane", "bounded_context",
        "aggregate_type", "aggregate_id", "aggregate_version", "event_type", "payload",
        "correlation_id", "actor_assertion_jti", "occurred_at"
      ],
      "properties": {
        "schema_version": { "const": 2 },
        "event_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string" },
        "event_plane": { "$ref": "#/$defs/event_plane" },
        "bounded_context": { "const": "deployment" },
        "aggregate_type": { "const": "deployment_instance" },
        "aggregate_id": { "type": "string", "format": "uuid" },
        "aggregate_version": { "type": "integer", "minimum": 1 },
        "event_type": { "type": "string", "pattern": "^RunnerDeploymentCommandV1\\.[0-9a-f-]{36}\\.[0-9a-f-]{36}$" },
        "payload": { "$ref": "#" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "actor_assertion_jti": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    },
    "signed_envelope_v2": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "signature_profile", "event_encoding", "event_bytes", "signature_key_id", "signature"],
      "properties": {
        "schema_version": { "const": 2 },
        "signature_profile": { "const": "crucible-domain-event-v2-exact-bytes" },
        "event_encoding": { "const": "application/json;base64url" },
        "event_bytes": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "signature_key_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$" },
        "signature": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" }
      }
    }
  }
}
