#!/usr/bin/env bash
# pre-commit hook wrapper.
# Installed by scripts/install-hooks.sh into .git/hooks/pre-commit as a symlink.
# Runs all repository-level pre-commit checks. Any failure blocks the commit.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

pick_python() {
  local candidate

  for candidate in "$@"; do
    if command -v "$candidate" >/dev/null 2>&1; then
      if "$candidate" --version >/dev/null 2>&1; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  done

  return 1
}

PYTHON_BIN="$(pick_python python3 /usr/bin/python3 /usr/local/bin/python3 /usr/bin/python3)"
if [[ -z "${PYTHON_BIN}" ]]; then
  echo "pre-commit: failed to locate a working python3 interpreter" >&2
  exit 1
fi

# 1. Enforce English-only comments / logs in source code (`.claude/rules/code-style.md` §6).
"$PYTHON_BIN" scripts/check-code-english.py
