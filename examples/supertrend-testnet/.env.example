# custos supertrend-testnet example — runtime config (NON-SECRET).
#
# Copy to .env and adjust. Docker Compose substitutes NATS and strategy values
# into the runner command; tenant and runner ids are used while generating
# runtime/.arx/runner.toml. Exchange credentials never belong here.
#
# NOTE: `cp .env.example .env` is safe only if you have not already created a
# .env — do not overwrite one you are using.

ARX_TENANT_ID=acme
ARX_RUNNER_ID=runner-testnet-1
ARX_NATS_URL=nats://nats:4222
# The reconcile subscription key: the runner listens on
# arx.<tenant>.deployment_spec.<strategy_id>, so publish the spec to that
# subject. This is the subscription id, not a field inside the spec.
ARX_STRATEGY_ID=supertrend-btcusdt
