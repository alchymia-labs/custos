{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git check-ignore:*)",
      "Bash(git ls-files:*)",
      "Bash(git mv:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$CLAUDE_FILE_PATHS\" ]; then for f in $CLAUDE_FILE_PATHS; do case \"$f\" in *.py) uv run ruff format --check \"$f\" 2>/dev/null || uv run ruff format \"$f\" ; uv run ruff check --fix \"$f\" 2>/dev/null || true ;; esac; done; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
